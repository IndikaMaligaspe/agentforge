# providers.yaml — Provider registry configuration for {{ project_name }}.
#
# This file is loaded at startup by ProviderRegistry.load_yaml().
# Register your external data providers here, or register them
# programmatically via ProviderRegistry.register() in your application code.
#
# Schema reference
# ----------------
# providers:
#   <slug>:                        # machine-readable provider identifier
#     display_name: string         # human-readable label (used in logs / UI)
#     env_prefix: string           # prefix for environment variable lookups
#                                  # e.g. "MY_PROVIDER" → MY_PROVIDER_API_KEY
#     credential_fields:           # maps fetcher payload key → env var suffix
#       <payload_key>: <ENV_SUFFIX>
#       # example: api_key: API_KEY  → reads MY_PROVIDER_API_KEY from environment
#     fetcher_metrics:             # list of metric descriptors to request
#       - key: <metric_key>
#         options: []              # provider-specific options (may be empty)
#     metric_mappings:             # how to normalize provider keys to common fields
#       - source_key: <provider_key>   # key in raw fetcher response
#         target_key: <common_key>     # normalized key used downstream
#
# Example (uncomment and adapt):
# --------------------------------
# providers:
#   my_provider:
#     display_name: "My Provider"
#     env_prefix: "MY_PROVIDER"
#     credential_fields:
#       api_key: API_KEY
#       account_id: ACCOUNT_ID
#       account_name: ACCOUNT_NAME
#       currency_code: CURRENCY
#     fetcher_metrics:
#       - key: revenue
#         options: []
#       - key: impressions
#         options: []
#       - key: clicks
#         options: []
#     metric_mappings:
#       - source_key: revenue
#         target_key: revenue
#       - source_key: impressions
#         target_key: impressions
#       - source_key: clicks
#         target_key: clicks

# No providers are registered by default.
# Add your own provider entries above or register them programmatically.
providers: {}
