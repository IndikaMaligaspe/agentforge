{# logging_middleware.py.j2 - Logging middleware for FastAPI applications #}
"""
Logging middleware for FastAPI applications.

This middleware:
- Generates a unique request ID for each request
- Logs request details (method, path, query params, etc.)
- Logs response details (status code, processing time)
- Captures and logs any unhandled exceptions
"""
from fastapi import Request
from starlette.middleware.base import BaseHTTPMiddleware
from starlette.types import ASGIApp, Receive, Scope, Send
import time
import traceback
from observability.logging import get_logger, RequestContext
{% if structured_logging %}
from structlog.contextvars import clear_contextvars
{% endif %}
from security.sanitizer import {% if enable_ip_pseudonymization %}pseudonymize_ip, {% endif %}sanitize_for_log

# Initialize logger
logger = get_logger(__name__)

class LoggingMiddleware(BaseHTTPMiddleware):
    """
    FastAPI middleware that logs all incoming requests and responses.
    Also provides request ID generation and tracking.
    """
    
    def __init__(self, app: ASGIApp):
        """
        Initialize the middleware.
        
        Args:
            app (ASGIApp): The ASGI application
        """
        super().__init__(app)
        
    async def dispatch(self, request: Request, call_next):
        """
        Process the request, log details, and track timing.
        
        Args:
            request (Request): The incoming request
            call_next (Callable): The next middleware or route handler
            
        Returns:
            Response: The response from the next middleware or route handler
        """
{% if structured_logging %}
        # Clear contextvars at the start of each request for a clean slate
        clear_contextvars()

{% endif %}
        # Generate a unique request ID
        request_id = RequestContext.set_request_id()

        # Get client IP address
        raw_host = request.client.host if request.client else "unknown"
        forwarded_for = request.headers.get("X-Forwarded-For")
        if forwarded_for:
            raw_host = forwarded_for.split(",")[0].strip()
            
        {% if enable_ip_pseudonymization %}
        # Pseudonymize the client IP before writing it to any log
        client_host = pseudonymize_ip(raw_host)
        {% else %}
        client_host = raw_host
        {% endif %}

        # Sanitize the request path to strip control characters / ANSI codes
        safe_path = sanitize_for_log(request.url.path)

        # Log the request
{% if structured_logging %}
        logger.info(
            "request_started",
            method=request.method,
            path=safe_path,
            query_params=sanitize_for_log(str(request.query_params)),
            client_host=client_host,
            user_agent=sanitize_for_log(
                request.headers.get("User-Agent", "unknown")
            ),
        )
        
{% else %}
        logger.info(
            f"Request started: {request.method} {safe_path}",
            extra={
                "props": {
                    "method": request.method,
                    "path": safe_path,
                    "query_params": sanitize_for_log(str(request.query_params)),
                    "client_host": client_host,
                    "request_id": request_id,
                    "user_agent": sanitize_for_log(
                        request.headers.get("User-Agent", "unknown")
                    ),
                }
            }
        )
        
{% endif %}
        # Time the request processing
        start_time = time.time()
        
        try:
            # Process the request
            response = await call_next(request)
            
            # Calculate processing time
            process_time = time.time() - start_time
            
            # Log the response
{% if structured_logging %}
            logger.info(
                "request_completed",
                method=request.method,
                path=safe_path,
                status_code=response.status_code,
                processing_time_ms=round(process_time * 1000, 2),
                content_type=response.headers.get("Content-Type", "unknown"),
            )
            
{% else %}
            logger.info(
                f"Request completed: {request.method} {safe_path}",
                extra={
                    "props": {
                        "method": request.method,
                        "path": safe_path,
                        "status_code": response.status_code,
                        "processing_time_ms": round(process_time * 1000, 2),
                        "request_id": request_id,
                        "content_type": response.headers.get("Content-Type", "unknown"),
                    }
                }
            )
            
{% endif %}
            return response
            
        except Exception as e:
            # Log any unhandled exceptions
            process_time = time.time() - start_time
{% if structured_logging %}
            logger.error(
                "request_failed",
                method=request.method,
                path=safe_path,
                error=sanitize_for_log(str(e)),
                traceback=traceback.format_exc(),
                processing_time_ms=round(process_time * 1000, 2),
            )
{% else %}
            logger.error(
                f"Request failed: {request.method} {safe_path}",
                extra={
                    "props": {
                        "method": request.method,
                        "path": safe_path,
                        "error": sanitize_for_log(str(e)),
                        "traceback": traceback.format_exc(),
                        "processing_time_ms": round(process_time * 1000, 2),
                        "request_id": request_id,
                    }
                }
            )
{% endif %}
            raise  # Re-raise the exception for FastAPI's exception handlers