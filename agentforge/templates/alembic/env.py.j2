{# alembic/env.py.j2 — Alembic migration environment for {{ project_name }} #}
"""Alembic migration environment."""

import os
from logging.config import fileConfig

from sqlalchemy import engine_from_config, pool

from alembic import context

# Alembic Config object provides access to values in alembic.ini
config = context.config

if config.config_file_name is not None:
    fileConfig(config.config_file_name)

# Override sqlalchemy.url from the environment variable at runtime
# so credentials never live in alembic.ini.
url = os.environ.get("{{ db_connection_env_var }}")
if not url:
    raise RuntimeError(
        "{{ db_connection_env_var }} is not set; cannot run Alembic migrations."
    )
config.set_main_option("sqlalchemy.url", url)

# Import the project's declarative Base so Alembic sees all table metadata.
# Add any additional model modules here after importing them.
try:
    from backend.db.base import Base  # noqa: F401  adjust if your Base lives elsewhere
    target_metadata = Base.metadata
except ImportError as exc:
    raise RuntimeError(
        "backend/db/base.py with a SQLAlchemy declarative Base is required for autogenerate. "
        "Create the file and define a Base = declarative_base() (or DeclarativeBase subclass) there."
    ) from exc


def run_migrations_offline() -> None:
    """Run migrations in 'offline' mode (no live DB connection required)."""
    url = config.get_main_option("sqlalchemy.url")
    context.configure(
        url=url,
        target_metadata=target_metadata,
        literal_binds=True,
        dialect_opts={"paramstyle": "named"},
    )
    with context.begin_transaction():
        context.run_migrations()


def run_migrations_online() -> None:
    """Run migrations in 'online' mode (connects to a live DB)."""
    connectable = engine_from_config(
        config.get_section(config.config_ini_section, {}),
        prefix="sqlalchemy.",
        poolclass=pool.NullPool,
    )
    with connectable.connect() as connection:
        context.configure(connection=connection, target_metadata=target_metadata)
        with context.begin_transaction():
            context.run_migrations()


if context.is_offline_mode():
    run_migrations_offline()
else:
    run_migrations_online()
