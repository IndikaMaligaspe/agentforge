{# project.yaml.j2 - Project configuration template #}
# {{ project_name }} Configuration
# Generated by agentforge

metadata:
  name: {{ project_name }}
  description: {{ description }}
  python_version: "{{ python_version }}"
  author: {{ author }}
  email: {{ email }}

agents:
{% for agent in agents_list %}
  - key: {{ agent.key }}
    class_name: {{ agent.class_name }}
    llm_model: {{ agent.llm_model }}
    system_prompt: >-
      {{ agent.system_prompt }}
    {% if agent.tools %}
    tools:
      {% for tool in agent.tools %}
      - name: {{ tool.name }}
        description: {{ tool.description }}
        {% if tool.mcp_resource %}
        mcp_resource: {{ tool.mcp_resource }}
        {% endif %}
      {% endfor %}
    {% endif %}
    needs_validation: {{ agent.needs_validation }}
    {% if agent.extra_return_keys %}
    extra_return_keys:
      {% for key in agent.extra_return_keys %}
      - {{ key }}
      {% endfor %}
    {% endif %}
{% endfor %}

database:
  backend: {{ db_backend }}
  {% if db_tables %}
  tables:
    {% for table in db_tables %}
    - {{ table }}
    {% endfor %}
  {% endif %}
  connection_env_var: {{ connection_env_var }}
  pool_size: {{ pool_size }}
  max_overflow: {{ max_overflow }}

workflow:
  enable_feedback_loop: {{ enable_feedback_loop }}
  enable_validation_node: {{ enable_validation_node }}
  router_llm_model: {{ router_llm_model }}
  default_intent: {{ default_intent }}
  max_feedback_attempts: {{ max_feedback_attempts }}

api:
  title: {{ api.title }}
  query_max_length: {{ query_max_length }}
  endpoints:
    {% for endpoint in api.endpoints %}
    - {{ endpoint }}
    {% endfor %}
  cors:
    origins:
      {% for origin in cors_origins %}
      - {{ origin }}
      {% endfor %}
    allow_credentials: {{ cors.allow_credentials }}

observability:
  enable_tracing: {{ enable_tracing }}
  tracing_provider: langfuse
  context_fields:
    {% for field in context_fields %}
    - {{ field }}
    {% endfor %}
  log_rotation_bytes: {{ log_rotation_bytes }}
  log_backup_count: {{ log_backup_count }}

security:
  enable_auth: {{ enable_auth }}
  api_key_env_var: {{ api_key_env_var }}
  enable_ip_pseudonymization: {{ enable_ip_pseudonymization }}