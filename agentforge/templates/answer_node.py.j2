"""
Answer Node for the LangGraph workflow.

This module contains the answer_node function that formats the final answer
based on the results from the agent dispatched by the supervisor_node.
"""

import re
import json
import time
from langchain_openai import ChatOpenAI
from langchain_core.messages import AIMessage
from ..state import AgentState
from observability.logging import get_logger, log_with_props, log_execution_time, RequestContext

# Initialize logger
logger = get_logger(__name__)

# Try to import WidgetFormatter with proper error handling
try:
    from widget_formatter import WidgetFormatter, DateTimeEncoder
    WIDGET_FORMATTER_AVAILABLE = True
except ImportError:
    logger.error("Failed to import WidgetFormatter. Widget functionality will be limited.", exc_info=True)
    WIDGET_FORMATTER_AVAILABLE = False
    
    # Create fallback implementations to avoid errors
    class FallbackWidgetFormatter:
        """Fallback implementation when real WidgetFormatter is unavailable"""
        @staticmethod
        def format_response(data, query="", widget_type="text", metadata=None, fallback=None):
            """Simple fallback that returns data as text widget"""
            return {
                "type": "text",
                "data": str(data),
                "query": query,
                "fallback": fallback or str(data)
            }
        
        @staticmethod
        def format_as_chart(data, query="", metadata=None):
            """Fallback chart formatter"""
            return {
                "type": "text",
                "data": f"Chart data: {str(data)}",
                "query": query,
                "fallback": f"Chart data: {str(data)}"
            }
    
    class FallbackDateTimeEncoder(json.JSONEncoder):
        """Simple fallback encoder that converts datetime to ISO format string"""
        def default(self, obj):
            if hasattr(obj, 'isoformat'):
                return obj.isoformat()
            return str(obj)
    
    # Assign fallbacks to the expected names
    WidgetFormatter = FallbackWidgetFormatter
    DateTimeEncoder = FallbackDateTimeEncoder

def answer_node(state: AgentState) -> AgentState:
    """ 
    Final Answer Generation Node
    
    This node formats the final answer based on the results from
    the agent dispatched by the supervisor_node.
    
    Args:
        state: The current workflow state
        
    Returns:
        Updated state with formatted final answer
    """
    node_name = "answer_node"
    request_id = RequestContext.get_request_id()
    
    # Log node entry
    log_with_props(logger, "info", f"Entering {node_name}",
                   node=node_name,
                   request_id=request_id,
                   intent=state.get('intent', '{{ default_intent }}'))
    
    try:
        # Initialize LLM
        llm = ChatOpenAI(model="gpt-4", temperature=0.3)
        
        # Determine which result to use based on intent
        intent = state.get('intent', '{{ default_intent }}')
        agent_name = state.get('agent_name', intent)
        
        # Get agent result from state
        if state.get("agent_result") and len(state["agent_result"]) > 0:
            result_obj = state["agent_result"][-1]
            log_with_props(logger, "info", "answer_node: reading from agent_result",
                          node=node_name,
                          request_id=request_id,
                          agent_name=agent_name)
        else:
            log_with_props(logger, "error",
                          "answer_node: NO result field found — returning error response",
                          node=node_name,
                          request_id=request_id)
            result_obj = {}
        
        # Check if this is an analytics result with chart_config
        if agent_name == "analytics" and result_obj.get('chart_config') and WIDGET_FORMATTER_AVAILABLE:
            log_with_props(logger, "info", f"Found chart_config in result",
                          node=node_name,
                          request_id=request_id,
                          chart_type=result_obj.get('chart_config', {}).get('chart_type'))
            
            # Format as chart widget
            formatted_widget = WidgetFormatter.format_as_chart(
                data=result_obj.get('chart_config'),
                query=state['query'],
                metadata=result_obj.get('analysis_data')
            )
            
            return {
                **state,
                'final_answer': formatted_widget
            }
        
        # Extract success status and error message from the result object
        success = result_obj.get('success', False)
        error_message = result_obj.get('error')
        output = result_obj.get('output', '')
        
        # Dump the full structure for debugging
        log_with_props(logger, "debug", f"Full result object in {node_name}",
                      node=node_name,
                      request_id=request_id,
                      result_obj=str(result_obj)[:500])  # Truncate to avoid huge logs
        
        if not success:
            # Handle error case with text widget
            log_with_props(logger, "warning", f"Agent query failed: {error_message}",
                          node=node_name,
                          request_id=request_id,
                          error=error_message)
                          
            error_response = WidgetFormatter.format_response(
                f"The query failed: {error_message}",
                query=state['query'],
                widget_type="text"
            )
            
            return {
                **state,
                'final_answer': error_response
            }
        
        # For SQL results, check if there's raw data to format as a table
        if 'data' in result_obj and result_obj['data']:
            log_with_props(logger, "info", "Formatting result as table widget",
                          node=node_name,
                          request_id=request_id,
                          row_count=len(result_obj['data']))
            
            # Format as table widget
            formatted_widget = WidgetFormatter.format_response(
                result_obj['data'],
                query=state['query'],
                widget_type="table",
                fallback=output
            )
            
            return {
                **state,
                'final_answer': formatted_widget
            }
        
        # Default case: format as text widget
        log_with_props(logger, "info", "Formatting result as text widget",
                      node=node_name,
                      request_id=request_id)
        
        formatted_widget = WidgetFormatter.format_response(
            output,
            query=state['query'],
            widget_type="text"
        )
        
        return {
            **state,
            'final_answer': formatted_widget
        }
        
    except Exception as e:
        # Log the error
        log_with_props(logger, "error", f"Error in {node_name}",
                      node=node_name,
                      request_id=request_id,
                      error=str(e),
                      exc_info=True)
        
        # Add error to state
        error_info = {
            'error': str(e),
            'node': node_name,
            'timestamp': time.time()
        }
        
        # Create a simple error response
        error_response = WidgetFormatter.format_response(
            f"An error occurred: {str(e)}",
            query=state.get('query', ''),
            widget_type="text"
        )
        
        return {
            **state,
            'errors': state.get('errors', []) + [error_info],
            'final_answer': error_response
        }