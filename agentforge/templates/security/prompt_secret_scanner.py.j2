"""
prompt_secret_scanner — detects secret values in LLM prompt strings before they are sent.

Pattern list is **append-only**: project owners should extend ``_SECRET_PATTERNS`` with
additional compiled regexes to suit their threat model. Do not remove or replace the
existing patterns; each one guards against a distinct, well-known credential format.
The patterns are deliberately conservative to avoid false positives on innocuous
hex/base64 strings that happen to be nearby in a prompt.
"""

import re


class SecretLeakError(ValueError):
    """Raised when a prompt about to be sent to an LLM matches a known secret pattern.

    Subclasses ``ValueError`` so callers can catch it alongside other validation errors
    without needing to import this module explicitly.
    """


# Append-only list of compiled regex patterns.
# Each pattern guards against a distinct credential format.
_SECRET_PATTERNS: list[re.Pattern[str]] = [
    # Labelled hex-32 app_secret (Facebook Graph API style)
    re.compile(r"app_secret\s*=\s*[a-fA-F0-9]{32}", re.IGNORECASE),
    # Facebook Graph API access token (EAA..., >=100 base-62 chars)
    re.compile(r"EAA[A-Za-z0-9]{100,}"),
    # Labelled access_token assignment or colon-value pair
    re.compile(r"access_token\s*[:=]\s*[A-Za-z0-9\-_\.]{20,}", re.IGNORECASE),
    # Bearer <token> HTTP authorization header value
    re.compile(r"\bBearer\s+[A-Za-z0-9\-_\.]{20,}"),
    # OpenAI-style API keys (sk-...)
    re.compile(r"\bsk-[A-Za-z0-9]{20,}"),
]


def scan_prompt_for_secrets(prompt: str) -> None:
    """Scan *prompt* for values matching any known secret pattern.

    Iterates over ``_SECRET_PATTERNS`` and raises :exc:`SecretLeakError` on the first
    match.  Returns ``None`` when no pattern matches (i.e. the prompt appears clean).

    Args:
        prompt: The full prompt string that is about to be sent to an LLM.

    Raises:
        SecretLeakError: If the prompt contains a value matching a known secret pattern.
    """
    for pattern in _SECRET_PATTERNS:
        if pattern.search(prompt):
            raise SecretLeakError(
                f"Prompt contains a value matching secret pattern: {pattern.pattern!r}"
            )
