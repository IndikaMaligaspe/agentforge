{# main.py.j2 - FastAPI application for the agent API
   Branches on entry_type:
     "intent_router" — classic free-text query; LLM routes to an agent by intent.
     "passthrough"   — caller supplies intent; LLM extracts structured inputs only.
     "direct"        — caller supplies typed {intent, inputs}; no LLM parsing at entry.
   All three entry types feed the same downstream pattern graph.

   Shared observability/error-handling boilerplate is extracted into the
   _make_error_response() Python helper below to avoid copy-paste across the
   passthrough and direct endpoint variants (intent_router uses inline handling
   for backwards compatibility).
#}
from fastapi import FastAPI, HTTPException, Request, Depends
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel, Field
import time
from typing import Union, Dict, Any, Optional
from contextlib import asynccontextmanager
{% if enable_tracing %}
from observability.tracing import trace_agent_run, langfuse
{% endif %}
from observability.logging import get_logger, RequestContext, log_with_props, log_execution_time
from middleware.logging_middleware import LoggingMiddleware
{% if auth_type == "jwt" %}
from fastapi import Header
from security.jwt import verify_token
from security.dtos import AuthError

async def auth_dep(authorization: str = Header(..., alias="Authorization")) -> dict:
    if not authorization.lower().startswith("bearer "):
        raise HTTPException(status_code=401, detail="Missing bearer token")
    try:
        return verify_token(authorization.split(" ", 1)[1])
    except AuthError as exc:
        raise HTTPException(status_code=401, detail=str(exc)) from exc
{% elif auth_type == "api_key" %}
from security.auth import get_api_key as auth_dep
{% endif %}
from security.sanitizer import sanitize_for_log
{% if entry_type == "direct" %}
from graph.direct_entry import DirectEntryRequest
{% endif %}

# Setup Logging with our centralized configuration
logger = get_logger(__name__)

{% if entry_type in ("passthrough", "direct") %}

def _make_error_response(e: Exception, request_id: str) -> dict:
    """Shared helper: log and format a generic error response.

    Extracted here to avoid duplicating the error-handling boilerplate across
    all three entry-type endpoint variants (intent_router / passthrough / direct).
    Full exception details are logged internally; only a generic message is
    returned to the caller.
    """
    log_with_props(logger, "error", "Error processing request",
                   error=str(e),
                   request_id=request_id,
                   exc_info=True)
    return {
        "success": False,
        "answer": None,
        "error": "An internal error occurred while processing your request. Please try again.",
        "trace_id": request_id,
    }


{% endif %}
@asynccontextmanager
async def lifespan(app: FastAPI):
    """
    Lifespan context manager for the FastAPI application.

    This function is called when the application starts up and shuts down.
    It performs the following tasks on startup:
    {% if enable_tracing %}1. Validates Langfuse authentication
    {% endif %}2. Warms up the AgentRegistry
    """
    logger.info("Starting {{ project_name }} API")

    {% if enable_tracing %}
    # Validate Langfuse auth at startup
    try:
        langfuse.auth_check()
        logger.info("Langfuse auth check passed")
    except Exception as e:
        logger.warning(f"Langfuse auth check failed: {e} — traces may not appear")
    {% endif %}

    # Warm up all registered agents (decorators run on import of the agents package)
    try:
        import agents  # triggers @AgentRegistry.register decorators
        from agents.registry import AgentRegistry
        logger.info(f"AgentRegistry ready: {AgentRegistry.get_all_keys()}")
    except Exception as e:
        logger.error(f"Failed to load AgentRegistry: {e}", exc_info=True)

    yield  # This is where the application runs

    # Shutdown logic (if any) would go here
    logger.info("Shutting down {{ project_name }} API")

app = FastAPI(title="{{ api.title }}", lifespan=lifespan)

# Add middleware (order matters - logging middleware should be first to catch all requests)
app.add_middleware(LoggingMiddleware)
app.add_middleware(
    CORSMiddleware,
    allow_origins=[{% for origin in cors_origins %}"{{ origin }}"{% if not loop.last %}, {% endif %}{% endfor %}],
    allow_methods=["*"],
    allow_headers=["*"],
    allow_credentials={{ allow_credentials }},
)

{% if entry_type == "intent_router" %}
# Bounded query length prevents ReDoS and unbounded LLM cost
class QueryRequest(BaseModel):
    query: str = Field(..., min_length=1, max_length={{ query_max_length }}, description="Natural language query")

class QueryResponse(BaseModel):
    success: bool = Field(..., description="Indicates if the query was processed successfully.")
    answer: Union[str, Dict[str, Any]] = Field(None, description="The answer to the query, which can be a string or a widget object.")
    error: Optional[str] = None
    trace_id: Optional[str] = None
{% elif entry_type == "passthrough" %}
# passthrough: caller supplies intent; LLM only extracts structured inputs from text.
class QueryRequest(BaseModel):
    intent: str = Field(..., min_length=1, max_length={{ query_max_length }}, description="Routing intent supplied by the caller")
    query: str = Field(..., min_length=1, max_length={{ query_max_length }}, description="Natural language text from which inputs are extracted")

class QueryResponse(BaseModel):
    success: bool = Field(..., description="Indicates if the request was processed successfully.")
    answer: Union[str, Dict[str, Any]] = Field(None, description="The answer to the request, which can be a string or a widget object.")
    error: Optional[str] = None
    trace_id: Optional[str] = None
{% elif entry_type == "direct" %}
class QueryResponse(BaseModel):
    success: bool = Field(..., description="Indicates if the request was processed successfully.")
    answer: Union[str, Dict[str, Any]] = Field(None, description="The answer to the request, which can be a string or a widget object.")
    error: Optional[str] = None
    trace_id: Optional[str] = None
