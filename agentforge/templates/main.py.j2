{% for endpoint in api.endpoints %}
{% if entry_type == "intent_router" %}
@app.post("{{ endpoint }}", response_model=QueryResponse)
def handle_query(request: QueryRequest{% if enable_auth %}, _key: str = Depends(auth_dep){% endif %}):
    """ Main endpoint to handle natural language queries """
    query = request.query
    request_id = RequestContext.get_request_id()

    # Log the incoming request
    log_with_props(logger, "info", "Received query request",
                  query_length=len(query),
                  query_preview=query[:100] + "..." if len(query) > 100 else query,
                  request_id=request_id)

    # Query length is enforced by QueryRequest.Field(min_length, max_length);
    # add domain-specific content validation here if your project needs it.

    try:
        # Measure execution time
        start_time = time.time()

        # Process the query through the workflow
        with log_execution_time(logger, "query_processing"):
            {% if enable_tracing %}
            result = trace_agent_run(query)
            {% else %}
            from graph.workflow import get_workflow
            workflow = get_workflow()
            result = workflow.invoke({"query": query})
            {% endif %}

        # Extract the final answer from the result
        final_answer = result.get('final_answer')

        # Log success
        execution_time = time.time() - start_time
        log_with_props(logger, "info", "Query processed successfully",
                      execution_time_ms=round(execution_time * 1000, 2),
                      has_answer=bool(final_answer),
                      request_id=request_id)

        # Return the response
        return {
            "success": True,
            "answer": final_answer,
            "error": None,
            "trace_id": request_id
        }

    except Exception as e:
        # Log full error internally; return only a generic message to the client
        log_with_props(logger, "error", "Error processing query",
                      error=str(e),
                      request_id=request_id,
                      exc_info=True)

        return {
            "success": False,
            "answer": None,
            "error": "An internal error occurred while processing your query. Please try again.",
            "trace_id": request_id
        }
{% elif entry_type == "passthrough" %}
@app.post("{{ endpoint }}", response_model=QueryResponse)
async def handle_query(request: QueryRequest{% if enable_auth %}, _key: str = Depends(auth_dep){% endif %}):
    """ Main endpoint to handle requests with caller-supplied intent (passthrough entry) """
    intent = request.intent
    query = request.query
    request_id = RequestContext.get_request_id()

    log_with_props(logger, "info", "Received passthrough request",
                  intent=intent,
                  query_length=len(query),
                  request_id=request_id)

    try:
        start_time = time.time()

        with log_execution_time(logger, "query_processing"):
            from graph.nodes.passthrough_node import passthrough_node
            from graph.workflow import get_workflow

            initial_state = {"query": query, "intent": intent}
            state_with_inputs = await passthrough_node(initial_state)
            workflow = get_workflow()
            result = workflow.invoke(state_with_inputs)

        final_answer = result.get('final_answer')
        execution_time = time.time() - start_time
        log_with_props(logger, "info", "Request processed successfully",
                      execution_time_ms=round(execution_time * 1000, 2),
                      has_answer=bool(final_answer),
                      request_id=request_id)
        return {
            "success": True,
            "answer": final_answer,
            "error": None,
            "trace_id": request_id,
        }

    except Exception as e:
        return _make_error_response(e, request_id)
{% elif entry_type == "direct" %}
@app.post("{{ endpoint }}", response_model=QueryResponse)
def handle_query(request: DirectEntryRequest{% if enable_auth %}, _key: str = Depends(auth_dep){% endif %}):
    """ Main endpoint to handle typed direct requests (direct entry — no LLM parsing) """
    intent = request.intent
    inputs = request.inputs
    request_id = RequestContext.get_request_id()

    log_with_props(logger, "info", "Received direct entry request",
                  intent=intent,
                  inputs_keys=list(inputs.keys()),
                  request_id=request_id)

    try:
        start_time = time.time()

        with log_execution_time(logger, "query_processing"):
            from graph.workflow import get_workflow
            initial_state = {"intent": intent, "inputs": inputs, "query": ""}
            workflow = get_workflow()
            result = workflow.invoke(initial_state)

        final_answer = result.get('final_answer')
        execution_time = time.time() - start_time
        log_with_props(logger, "info", "Request processed successfully",
                      execution_time_ms=round(execution_time * 1000, 2),
                      has_answer=bool(final_answer),
                      request_id=request_id)
        return {
            "success": True,
            "answer": final_answer,
            "error": None,
            "trace_id": request_id,
        }

    except Exception as e:
        return _make_error_response(e, request_id)
{% endif %}
{% endfor %}
