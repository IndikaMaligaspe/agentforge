{# main.py.j2 - FastAPI application for the agent API #}
from fastapi import FastAPI, HTTPException, Request, Depends
from json_encoder import CustomJsonEncoder
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel, Field
import time
from typing import Union, Dict, Any, Optional
from contextlib import asynccontextmanager
from guardrails_validators import validate_query
{% if enable_tracing %}
from observability.tracing import trace_agent_run, langfuse
{% endif %}
from observability.logging import get_logger, RequestContext, log_with_props, log_execution_time
from middleware.logging_middleware import LoggingMiddleware
{% if enable_auth %}
from security.auth import get_api_key
{% endif %}
from security.sanitizer import sanitize_for_log

# Setup Logging with our centralized configuration
logger = get_logger(__name__)

@asynccontextmanager
async def lifespan(app: FastAPI):
    """
    Lifespan context manager for the FastAPI application.
    
    This function is called when the application starts up and shuts down.
    It performs the following tasks on startup:
    {% if enable_tracing %}1. Validates Langfuse authentication
    {% endif %}2. Warms up the AgentRegistry
    """
    logger.info("Starting {{ project_name }} API")
    
    {% if enable_tracing %}
    # Validate Langfuse auth at startup
    try:
        langfuse.auth_check()
        logger.info("Langfuse auth check passed")
    except Exception as e:
        logger.warning(f"Langfuse auth check failed: {e} — traces may not appear")
    {% endif %}
    
    # Warm up all registered agents
    try:
        from agents.registry import AgentRegistry
        AgentRegistry.warm_up()
        logger.info(f"AgentRegistry warmed up: {AgentRegistry.list_keys()}")
    except Exception as e:
        logger.error(f"Failed to warm up AgentRegistry: {e}", exc_info=True)
    
    yield  # This is where the application runs
    
    # Shutdown logic (if any) would go here
    logger.info("Shutting down {{ project_name }} API")

app = FastAPI(title="{{ api.title }}", json_encoder=CustomJsonEncoder, lifespan=lifespan)

# Add middleware (order matters - logging middleware should be first to catch all requests)
app.add_middleware(LoggingMiddleware)
app.add_middleware(
    CORSMiddleware,
    allow_origins=[{% for origin in cors_origins %}"{{ origin }}"{% if not loop.last %}, {% endif %}{% endfor %}],
    allow_methods=["*"],
    allow_headers=["*"],
    allow_credentials={{ allow_credentials }},
)

# Bounded query length prevents ReDoS and unbounded LLM cost
class QueryRequest(BaseModel):
    query: str = Field(..., min_length=1, max_length={{ query_max_length }}, description="Natural language query")

class QueryResponse(BaseModel):
    success: bool = Field(..., description="Indicates if the query was processed successfully.")
    answer: Union[str, Dict[str, Any]] = Field(None, description="The answer to the query, which can be a string or a widget object.")
    error: Optional[str] = None
    trace_id: Optional[str] = None

@app.get("/")
def read_root():
    logger.debug("Root endpoint accessed")
    return {"message": "Welcome to the {{ api.title }}"}

@app.get("/health")
def health_check():
    logger.debug("Health check endpoint accessed")
    return {"status": "healthy"}

{% for endpoint in api.endpoints %}
@app.post("{{ endpoint }}", response_model=QueryResponse)
def handle_query(request: QueryRequest{% if enable_auth %}, _key: str = Depends(get_api_key){% endif %}):
    """ Main endpoint to handle natural language queries """
    query = request.query
    request_id = RequestContext.get_request_id()
    
    # Log the incoming request
    log_with_props(logger, "info", "Received query request",
                  query_length=len(query),
                  query_preview=query[:100] + "..." if len(query) > 100 else query,
                  request_id=request_id)
    
    # Validate the query
    validation_result = validate_query(query)
    if not validation_result['valid']:
        log_with_props(logger, "warning", "Query validation failed",
                      error=validation_result['reason'],
                      request_id=request_id)
        return {
            "success": False,
            "answer": None,
            "error": f"Invalid query: {validation_result['reason']}",
            "trace_id": request_id
        }
    
    try:
        # Measure execution time
        start_time = time.time()
        
        # Process the query through the workflow
        with log_execution_time(logger, "query_processing"):
            {% if enable_tracing %}
            result = trace_agent_run(query)
            {% else %}
            # Import here to avoid circular imports
            from graph.workflow import get_workflow
            
            # Initialize the workflow with the query
            workflow = get_workflow()
            result = workflow.invoke({"query": query})
            {% endif %}
        
        # Extract the final answer from the result
        final_answer = result.get('final_answer')
        
        # Log success
        execution_time = time.time() - start_time
        log_with_props(logger, "info", "Query processed successfully",
                      execution_time_ms=round(execution_time * 1000, 2),
                      has_answer=bool(final_answer),
                      request_id=request_id)
        
        # Return the response
        return {
            "success": True,
            "answer": final_answer,
            "error": None,
            "trace_id": request_id
        }
        
    except Exception as e:
        # Log full error internally; return only a generic message to the client
        log_with_props(logger, "error", "Error processing query",
                      error=str(e),
                      request_id=request_id,
                      exc_info=True)

        return {
            "success": False,
            "answer": None,
            "error": "An internal error occurred while processing your query. Please try again.",
            "trace_id": request_id
        }
{% endfor %}