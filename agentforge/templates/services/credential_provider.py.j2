"""Credential provider abstraction for tenant-scoped secret retrieval.

This module defines the {protocol/factory} that the rest of the app uses to
fetch tenant credentials. Two implementations ship by default:

  * EnvCredentialProvider: Phase-1 single-tenant. Reads from Settings (.env).
{% if multi_tenancy.credential_provider == "db" %}
  * PlatformDBCredentialProvider: DB-backed lookup. Uses asyncpg via
    platform_db.get_platform_pool.
{% endif %}

Project-specific credential schemas should extend `TenantCredentials` rather
than replace it — the Protocol method signatures are deliberately generic.

The active implementation is selected at app startup via
`build_credential_provider(settings)`.
"""

from __future__ import annotations

from typing import Optional, Protocol, runtime_checkable

from pydantic import BaseModel, SecretStr

{% if multi_tenancy.credential_provider == "db" %}
from backend.services.platform_db import _to_int_id, get_platform_pool
{% endif %}

if False:  # TYPE_CHECKING
    from backend.config.settings import Settings


class TenantCredentials(BaseModel):
    """Per-tenant credentials returned by a CredentialProvider.

    Frozen to prevent accidental mutation after fetch. Project-specific
    credential models should subclass this and add typed fields:

        class MetaCredentials(TenantCredentials):
            access_token: SecretStr
            ad_account_id: int
    """

    model_config = {"frozen": True}

    user_id: str
    team_id: str
    secrets: dict[str, SecretStr] = {}


@runtime_checkable
class CredentialProvider(Protocol):
    """Async interface for tenant-scoped credential retrieval."""

    async def get_credentials(
        self, user_id: str, team_id: str
    ) -> TenantCredentials:
        """Return credentials for the (user, team) pair.

        Raises:
            LookupError: if no credentials exist for the pair.
        """
        ...

    async def list_accounts(
        self, user_id: str, team_id: str
    ) -> list[str]:
        """List account ids the (user, team) is allowed to act on.

        Used by the account_gate middleware to validate the X-Account-Id
        header. Returning an empty list means no accounts — the gate
        will reject every request.
        """
        ...

    async def get_account_credentials(
        self, user_id: str, team_id: str, account_id: str
    ) -> TenantCredentials:
        """Return credentials scoped to a specific account.

        Default implementations may delegate to `get_credentials` and ignore
        the account_id; tenants with per-account credentials should override.
        """
        ...


class EnvCredentialProvider:
    """Phase-1 single-tenant provider. Reads from Settings (.env).

    Treats every (user, team) request as the same tenant — the singleton
    one defined in `.env`. List of allowed accounts is empty by default;
    projects override `list_accounts` if they need account scoping in
    Phase 1.
    """

    def __init__(self, settings: "Settings") -> None:
        self._settings = settings

    async def get_credentials(
        self, user_id: str, team_id: str
    ) -> TenantCredentials:
        return TenantCredentials(
            user_id=user_id,
            team_id=team_id,
            secrets={},  # projects extend this with their fields
        )

    async def list_accounts(
        self, user_id: str, team_id: str
    ) -> list[str]:
        return []

    async def get_account_credentials(
        self, user_id: str, team_id: str, account_id: str
    ) -> TenantCredentials:
        return await self.get_credentials(user_id, team_id)


{% if multi_tenancy.credential_provider == "db" %}
class PlatformDBCredentialProvider:
    """DB-backed provider. Uses asyncpg via `platform_db.get_platform_pool`.

    The platform DB schema is project-specific. Each project should override
    `_lookup_credentials` and `_lookup_accounts` with their actual queries —
    the implementations here are stubs that raise NotImplementedError so a
    deployment can't accidentally start with no credential lookup.

    The `_to_int_id` helper coerces JWT claim strings to int at the asyncpg
    boundary; projects with bigint user/team ids should use it.
    """

    def __init__(self, settings: "Settings") -> None:
        if not settings.platform_db_url:
            raise RuntimeError(
                "PlatformDBCredentialProvider requires Settings.platform_db_url. "
                "Set PLATFORM_DB_URL in `.env` or provide PLATFORM_DB_HOST/USER/"
                "PW/PORT/NAME for assembled-DSN mode."
            )
        self._settings = settings

    async def _lookup_credentials(
        self, user_id: int, team_id: int
    ) -> TenantCredentials:
        raise NotImplementedError(
            "Override _lookup_credentials with your platform DB query"
        )

    async def _lookup_accounts(
        self, user_id: int, team_id: int
    ) -> list[str]:
        raise NotImplementedError(
            "Override _lookup_accounts with your platform DB query"
        )

    async def get_credentials(
        self, user_id: str, team_id: str
    ) -> TenantCredentials:
        return await self._lookup_credentials(
            _to_int_id(user_id, "user_id"),
            _to_int_id(team_id, "team_id"),
        )

    async def list_accounts(
        self, user_id: str, team_id: str
    ) -> list[str]:
        return await self._lookup_accounts(
            _to_int_id(user_id, "user_id"),
            _to_int_id(team_id, "team_id"),
        )

    async def get_account_credentials(
        self, user_id: str, team_id: str, account_id: str
    ) -> TenantCredentials:
        creds = await self.get_credentials(user_id, team_id)
        return creds.model_copy(update={"secrets": {**creds.secrets}})
{% endif %}


def build_credential_provider(settings: "Settings") -> CredentialProvider:
    """Factory: returns the right provider per settings.

    Selected via `settings.credential_provider` field which mirrors
    `multi_tenancy.credential_provider` from the project config.
    """
    provider = settings.credential_provider
{% if multi_tenancy.credential_provider == "db" %}
    if provider == "db":
        return PlatformDBCredentialProvider(settings)
{% endif %}
    if provider == "env":
        return EnvCredentialProvider(settings)
    raise ValueError(
        f"Unknown credential_provider: {provider!r}. "
        "Expected one of: 'env'{% if multi_tenancy.credential_provider == 'db' %}, 'db'{% endif %}."
    )
