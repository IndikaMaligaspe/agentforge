"""Account-scoping middleware for multi-tenant requests.

Provides `require_valid_account` — a FastAPI dependency that:
  * Reads the `{{ multi_tenancy.account_scoping_header }}` header.
  * Looks up the calling user's tenant via JWT claims (the JWT must
    already be verified upstream — typically by `verify_token` and
    optionally `require_permission`).
  * Validates the header value against the tenant's allowed accounts
    via `CredentialProvider.list_accounts`.

Returns the validated account_id string. Raises HTTPException 400 if
the header is missing, 403 if the account is not in the tenant's
allow-list.

Cache note: `list_accounts` is called once per request — wire your
provider's caching at that layer if list lookups are expensive.
"""

from __future__ import annotations

from typing import Any

from fastapi import Header, HTTPException, Request, status

from backend.security.jwt import verify_token
from backend.services.credential_provider import (
    CredentialProvider,
    build_credential_provider,
)

ACCOUNT_HEADER: str = "{{ multi_tenancy.account_scoping_header }}"


def _extract_user_team(claims: dict[str, Any]) -> tuple[str, str]:
    """Pull user_id and team_id from JWT claims.

    Falls back to legacy claim names (sub) when user_id is absent.
    Defaults team_id to "default" — single-tenant deployments use the
    fallback rather than rejecting unscoped tokens.
    """
    user_id = (
        claims.get("user_id")
        or claims.get("sub")
        or "anonymous"
    )
    team_id = claims.get("team_id", "default")
    return str(user_id), str(team_id)


async def require_valid_account(
    request: Request,
    account_id: str | None = Header(default=None, alias=ACCOUNT_HEADER),
) -> str:
    """FastAPI dependency: validate the account header against tenant allow-list.

    Uses the request-scoped credential provider — wire it into your app's
    state at startup (e.g. `app.state.credential_provider = ...`) so the
    same instance is reused across requests. Falls back to building one
    from `request.app.state.settings` if not present.
    """
    if not account_id:
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail=f"Missing required header: {ACCOUNT_HEADER}",
        )

    # Extract claims from the verified JWT (verify_token must have run upstream).
    auth_header = request.headers.get("authorization", "")
    if not auth_header.lower().startswith("bearer "):
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="Missing or malformed Authorization header",
        )
    token = auth_header.split(" ", 1)[1]
    claims = verify_token(token)

    user_id, team_id = _extract_user_team(claims)

    provider: CredentialProvider | None = getattr(
        request.app.state, "credential_provider", None
    )
    if provider is None:
        # Fallback: build per-request. Production apps should wire the
        # provider at startup; this branch exists so dev deployments
        # don't need to remember the wiring step.
        settings = request.app.state.settings
        provider = build_credential_provider(settings)

    allowed = await provider.list_accounts(user_id, team_id)
    if account_id not in allowed:
        raise HTTPException(
            status_code=status.HTTP_403_FORBIDDEN,
            detail=f"Account {account_id!r} not in tenant allow-list",
        )

    return account_id
