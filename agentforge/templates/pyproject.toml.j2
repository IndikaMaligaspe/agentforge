{# pyproject.toml.j2 - Python project configuration #}
[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "{{ description }}"
readme = "README.md"
requires-python = ">={{ python_version }}"
license = {text = "MIT"}
authors = [
  {name = "{{ author }}", email = "{{ author_email }}"}
]
keywords = ["agents", "langchain", "langgraph", "llm"]
classifiers = [
  "Development Status :: 3 - Alpha",
  "Intended Audience :: Developers",
  "License :: OSI Approved :: MIT License",
  "Programming Language :: Python :: {{ python_version }}",
]
dependencies = [
  "fastapi>=0.110",
  "uvicorn[standard]>=0.29",
  "pydantic>=2.7",
  "langgraph>=0.1",
  "langchain-openai>=0.1",
  "sqlalchemy>=2.0",
  "alembic>=1.13",
  {% if db_backend == "postgres" %}
  "psycopg[binary]>=3.1",
  {% elif db_backend == "mysql" %}
  "pymysql>=1.1",
  {% endif %}
  {% if enable_tracing %}
  "langfuse>=2.35",
  {% endif %}
  {% if has_mcp %}
  # langchain-mcp-adapters is pre-1.0; class names may change across minor releases.
  # Review backend/services/mcp_client.py imports after any version bump.
  "langchain-mcp-adapters>=0.1.0,<0.2.0",
  {% endif %}
  "python-dotenv>=1.0",
  "rich>=13.7",
]

[project.scripts]
{{ project_name }} = "backend.main:app"

[tool.hatch.build.targets.wheel]
packages = ["backend"]

[tool.hatch.envs.default]
dependencies = [
  "pytest>=8",
  "pytest-cov",
  "ruff",
  "mypy",
]

[tool.hatch.envs.default.scripts]
test = "pytest tests/ -v --cov=backend --cov-report=term-missing"
lint = "ruff check backend/"
typecheck = "mypy backend/ --ignore-missing-imports"
fmt = "ruff format backend/"

[tool.ruff]
line-length = 100
target-version = "py{{ python_version }}"
