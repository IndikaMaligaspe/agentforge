{# .env.example.j2 - Example environment variables file #}
# {{ project_name }} Environment Variables
# Copy this file to .env and fill in the values

# Environment (development, testing, staging, production)
ENVIRONMENT=development

# LLM API Keys
OPENAI_API_KEY=sk-your-openai-key-here

{% if db_backend == "postgres" %}
# PostgreSQL Database (psycopg3 driver)
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/{{ project_name }}
{% elif db_backend == "mysql" %}
# MySQL Database (pymysql driver — pure Python, no native libs required)
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/{{ project_name }}
{% elif db_backend == "sqlite" %}
# SQLite Database
DATABASE_URL=sqlite:///./app.db
{% endif %}

{% if enable_auth and auth_type == "api_key" %}
# API Authentication
{{ api_key_env_var }}=your-secret-api-key-here
{% endif %}

{% if enable_tracing %}
# Langfuse Tracing
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com
{% endif %}

# Logging
LOG_LEVEL=INFO
