# API Keys
OPENAI_API_KEY=your-openai-api-key-here
{% if security.enable_auth and security.auth_type == "api_key" %}
{{ security.api_key_env_var }}=your-api-key-here
{% endif %}

{% if auth_type == "jwt" and jwt_algorithm == "HS256" %}
# JWT Authentication (HS256 — symmetric secret)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
{% endif %}

{% if auth_type == "jwt" and jwt_issuer %}
JWT_ISSUER={{ jwt_issuer }}
{% endif %}

{% if auth_type == "jwt" and jwt_audience %}
JWT_AUDIENCE={{ jwt_audience }}
{% endif %}

# Database Connection
{{ db_connection_env_var }}={% if db_backend == "postgres" %}postgresql://username:password@localhost:5432/{{ project_name }}{% elif db_backend == "mysql" %}mysql://username:password@localhost:3306/{{ project_name }}{% elif db_backend == "sqlite" %}sqlite:///{{ project_name }}.db{% elif db_backend == "mssql" %}mssql+pyodbc://username:password@localhost:1433/{{ project_name }}?driver=ODBC+Driver+17+for+SQL+Server{% elif db_backend == "bigquery" %}your-bigquery-credentials-file.json{% endif %}

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json  # json or text

{% if observability.enable_tracing %}
# Tracing ({{ observability.tracing_provider }})
{% if observability.tracing_provider == "langfuse" %}
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_PROJECT=your-project-name
{% endif %}
{% endif %}

# Server Settings
PORT=8000
HOST=0.0.0.0
WORKERS=1
RELOAD=true  # Set to false in production
