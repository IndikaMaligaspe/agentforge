@runtime_checkable
class {{ NAME }}Store(Protocol):
    """CRUD interface for {{ store.name }} records."""

    async def get(self, record_id: str) -> Optional[{{ NAME }}Record]:
        """Return the record by id, or None if absent."""
        ...

    async def put(self, record: {{ NAME }}Record) -> None:
        """Insert or upsert the record."""
        ...

    async def delete(self, record_id: str) -> None:
        """Remove the record. No-op if it doesn't exist."""
        ...

    async def list(self, limit: int = 100) -> list[{{ NAME }}Record]:
        """Return up to `limit` records (no defined ordering by default)."""
        ...


class InMemory{{ NAME }}Store:
    """In-process store. The dev default — never use in production.

    Useful for tests and single-process deployments. State is per-process
    and lost on restart.
    """

    def __init__(self) -> None:
        self._records: dict[str, {{ NAME }}Record] = {}

    async def get(self, record_id: str) -> Optional[{{ NAME }}Record]:
        return self._records.get(record_id)

    async def put(self, record: {{ NAME }}Record) -> None:
        self._records[record.id] = record

    async def delete(self, record_id: str) -> None:
        self._records.pop(record_id, None)

    async def list(self, limit: int = 100) -> list[{{ NAME }}Record]:
        return list(self._records.values())[:limit]

