def build_{{ store.name }}_store(settings: "Settings") -> {{ NAME }}Store:
    """Factory: select a store impl based on settings.{{ store.name }}_store_backend.

    Default: "{{ store.default }}" (set via {{ NAME_UPPER }}_STORE_BACKEND env var).
    """
    backend = getattr(settings, "{{ store.name }}_store_backend", "{{ store.default }}")
{% if "bigquery" in store.backends %}
    if backend == "bigquery":
        from backend.services.bigquery_rest_client import BigQueryRestClient
        # Construct your client with the relevant credentials/project_id.
        return BigQuery{{ NAME }}Store(client=BigQueryRestClient())  # noqa: needs project args
{% endif %}
{% if "postgres" in store.backends %}
    if backend == "postgres":
        # Wire your asyncpg pool here — typically via app.state.db_pool.
        raise RuntimeError(
            "Postgres{{ NAME }}Store factory must be wired with an asyncpg "
            "Pool. Override this factory or pass the pool explicitly."
        )
{% endif %}
    if backend == "memory":
        return InMemory{{ NAME }}Store()
    raise ValueError(
        f"Unknown {{ store.name }}_store_backend: {backend!r}. "
        "Expected one of: {{ store.backends | join(', ') }}."
    )
