"""
reducer_node.py — Result-merging reducer for the fanout execution pattern.
Auto-generated by agentforge (pattern: fanout).

This module implements the reduce step of the fanout execution pattern.
After all parallel agent branches complete, LangGraph collects their
individual result items into ``{{ fanout_results_field }}`` using the
``Annotated[list, operator.add]`` reducer declared in the state type.

``reducer_node`` then post-processes that accumulated list according to
the configured reducer strategy:

    reducer = "{{ fanout_reducer }}"

Strategies
----------
concat
    The raw list of per-agent result dicts is preserved as-is.
    Output key: ``output`` → list[dict]

merge_dict
    Each per-agent result dict is merged (later keys win on collision)
    into a single flat dict.
    Output key: ``output`` → dict

The strategy is selected at scaffold time; only the active helper is
emitted so there is no dead code in the generated file.
"""
from __future__ import annotations

from typing import Any

from observability.logging import get_logger

logger = get_logger(__name__)

# Reducer strategy resolved at scaffold time.
_REDUCER_STRATEGY: str = "{{ fanout_reducer }}"

# State field that carries the per-agent results list.
_RESULTS_FIELD: str = "{{ fanout_results_field }}"

{% if fanout_reducer == "concat" %}
def _reduce(results: list[Any]) -> list[Any]:
    """Return the raw per-agent result list unchanged."""
    return list(results)
{% else %}
def _reduce(results: list[Any]) -> dict[str, Any]:
    """Merge all per-agent result dicts; later keys win on collision."""
    merged: dict[str, Any] = {}
    for item in results:
        if isinstance(item, dict):
            merged.update(item)
    return merged
{% endif %}


def reducer_node(state: dict[str, Any]) -> dict[str, Any]:
    """Merge per-agent results collected in ``{{ fanout_results_field }}``.

    Called once after all parallel agent branches in the fan-out superstep
    have completed.  Reads the accumulated results list and applies the
    configured reducer strategy.

    Args:
        state: The merged graph state after all parallel Send branches
               have returned.  ``state["{{ fanout_results_field }}"]``
               contains the combined list of per-agent result payloads.

    Returns:
        A state patch dict containing ``output`` (the reduced result) and
        ``{{ fanout_results_field }}`` reset to an empty list so that the
        field is clean if the graph is re-entered.
    """
    raw_results: list[Any] = state.get(_RESULTS_FIELD, [])
    logger.debug(
        "fanout reducer: merging %d results with strategy '%s'",
        len(raw_results),
        _REDUCER_STRATEGY,
    )

    output = _reduce(raw_results)

    return {
        "output": output,
        _RESULTS_FIELD: [],  # reset for idempotent re-runs
    }
