"""
composer_node.py — LLM-based final answer synthesiser for the planner pattern.
Auto-generated by agentforge (pattern: planner).

SCAFFOLD RISK — STATE SIZE:
    All step results are serialised into the LLM prompt. For large result
    payloads, consider truncating or summarising ``step_results`` before
    passing it here. A checkpointer with TTL prevents stale state accumulation
    across sessions.

Config values injected at scaffold time:
    max_replans = {{ planner_max_replans }}
"""
from __future__ import annotations

import json
from typing import Any

from langchain_openai import ChatOpenAI
from langchain_core.messages import AIMessage, SystemMessage, HumanMessage
from langchain_core.runnables import RunnableConfig

from observability.logging import get_logger

logger = get_logger(__name__)

_COMPOSER_SYSTEM_PROMPT = """You are a response composer. Given the original user request \
and the collected results from executing a plan, write a clear, complete, and helpful final \
answer.

Guidelines:
- Answer the user's question fully using the step results as evidence.
- Be concise but thorough.
- Format the response for readability (use bullet points or sections where appropriate).
- Do not mention internal step ids or tool names unless directly relevant.
- Return ONLY the final answer — no preamble, no meta-commentary."""


async def composer_node(
    state: dict[str, Any], config: RunnableConfig
) -> dict[str, Any]:
    """Synthesise a final answer from all solver step results.

    Reads ``state["query"]`` and ``state["step_results"]``.
    Writes the composed answer to ``state["output"]``.

    Args:
        state: Current graph state dict.
        config: LangGraph runnable config (passed through to LLM).

    Returns:
        Partial state update dict with ``output`` set to the final answer string.
    """
    query: str = state.get("query", "")
    step_results: dict[str, Any] = state.get("step_results", {})

    results_text = json.dumps(step_results, indent=2, default=str)
    logger.info(
        "composer_node: composing final answer from %d step results",
        len(step_results),
    )

    messages = [
        SystemMessage(content=_COMPOSER_SYSTEM_PROMPT),
        SystemMessage(content=f"Step results:\n{results_text}"),
        HumanMessage(content=query),
    ]

    llm = ChatOpenAI(model="{{ planner_llm_model }}", temperature={{ planner_llm_temperature }})
    response: AIMessage = await llm.ainvoke(messages, config=config)
    output: str = response.content if hasattr(response, "content") else str(response)

    logger.info("composer_node: final answer composed (%d chars)", len(output))
    return {"output": output}
