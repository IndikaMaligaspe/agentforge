"""
plan_and_run_node.py — LLM-driven plan generator for the planner pattern.
Auto-generated by agentforge (pattern: planner).

SCAFFOLD RISK — IDEMPOTENCY:
    Steps in the plan may be replayed on replan. Ensure that ``http`` and
    ``agent`` tools are idempotent or include idempotency keys in their args.
    A replan after a partial execution may trigger duplicate side-effects for
    any non-idempotent step that already ran successfully.

SCAFFOLD RISK — STATE SIZE:
    Plan step results accumulate in ``PlannerState.step_results`` on every
    solver pass. For long plans or multi-replan chains, state size may balloon.
    Consider adding a summarisation step before ComposerNode and configuring a
    checkpointer with a short TTL to prune stale intermediate results.

Config values injected at scaffold time:
    max_replans      = {{ planner_max_replans }}
    max_concurrency  = {{ planner_max_concurrency }}
    tools declared   = {{ planner_tool_names | join(", ") if planner_tool_names else "(none)" }}
"""
from __future__ import annotations

import json
import re
from typing import Any

from langchain_openai import ChatOpenAI
from langchain_core.messages import AIMessage, HumanMessage, SystemMessage
from langchain_core.runnables import RunnableConfig

from observability.logging import get_logger

logger = get_logger(__name__)

# ── Scaffold-time constants (never hardcoded) ─────────────────────────────────

_MAX_REPLANS: int = {{ planner_max_replans }}

# Tool names declared in project.yaml — planner prompt enumerates these.
_TOOL_NAMES: list[str] = [
{% for tool_name in planner_tool_names %}
    "{{ tool_name }}",
{% endfor %}
]

# ── Prompt ────────────────────────────────────────────────────────────────────
{% raw %}
_PLANNER_SYSTEM_PROMPT = """You are a planning assistant. Break the user request into a \
JSON array of executable steps.

Available tools:
{tools}

Each step MUST be a JSON object with these EXACT fields:
  "id"   — unique step identifier, e.g. "step1", "step2"
  "tool" — one of the available tool names listed above
  "args" — dict of keyword arguments for the tool
  "deps" — list of step ids this step depends on (empty list [] if none)

Steps may reference results from dependency steps using JSON Pointer syntax:
  "${stepN/field}"  — value of field "field" from step "stepN" result

Rules:
1. Only use tools from the Available tools list.
2. deps must reference ids declared earlier in the same plan.
3. No dependency cycles.
4. Return ONLY the JSON array — no prose, no markdown fences.

Example (2-step plan):
[
  {"id": "step1", "tool": "fetch_data", "args": {"query": "active items"}, "deps": []},
  {"id": "step2", "tool": "analyse",    "args": {"data": "${step1/result}"}, "deps": ["step1"]}
]"""
{% endraw %}


def _build_prompt(query: str, context: dict[str, Any], replan_reason: str | None) -> list:
    """Build the messages list for the plan LLM call.

    Args:
        query: The original user query.
        context: Caller-supplied context dict (passed verbatim as JSON).
        replan_reason: If replanning, the structured error from the precheck or
                       validator node that explains why the previous plan failed.

    Returns:
        A list of LangChain message objects ready for ``llm.invoke``.
    """
    tool_list = "\n".join(f"  - {t}" for t in _TOOL_NAMES) if _TOOL_NAMES else "  (none)"
    system = _PLANNER_SYSTEM_PROMPT.format(tools=tool_list)
    messages: list = [SystemMessage(content=system)]

    if context:
        messages.append(
            SystemMessage(content=f"Context:\n{json.dumps(context, indent=2)}")
        )

    if replan_reason:
        messages.append(
            SystemMessage(
                content=(
                    f"Your previous plan was rejected. Reason:\n{replan_reason}\n\n"
                    "Generate a corrected plan that addresses the above issues."
                )
            )
        )

    messages.append(HumanMessage(content=query))
    return messages


def _parse_plan(raw: str) -> list[dict[str, Any]]:
    """Extract and parse the JSON array from the LLM response.

    The LLM may wrap the array in markdown fences; strip them before parsing.

    Args:
        raw: Raw string content returned by the plan LLM.

    Returns:
        Parsed list of step dicts.

    Raises:
        ValueError: If the response cannot be parsed as a JSON array.
    """
    # Strip optional markdown code fence.
    text = re.sub(r"^```(?:json)?\s*", "", raw.strip(), flags=re.IGNORECASE)
    text = re.sub(r"\s*```$", "", text.strip())
    try:
        plan = json.loads(text)
    except json.JSONDecodeError as exc:
        raise ValueError(f"LLM did not return valid JSON: {exc}\nRaw response:\n{raw}") from exc
    if not isinstance(plan, list):
        raise ValueError(f"Expected a JSON array of steps, got {type(plan).__name__}")
    return plan


async def plan_and_run_node(state: dict[str, Any], config: RunnableConfig) -> dict[str, Any]:
    """Generate a JSON DAG plan via LLM.

    Reads ``state["query"]``, ``state["context"]``, and
    ``state["replan_reason"]`` (if replanning). Writes the parsed plan list
    back to ``state["plan"]`` and increments ``state["replan_count"]`` when a
    previous plan existed.

    Args:
        state: Current graph state dict.
        config: LangGraph runnable config (passed through to LLM).

    Returns:
        Partial state update dict with ``plan``, ``replan_count``, and
        ``step_results`` reset to empty.
    """
    query: str = state.get("query", "")
    context: dict[str, Any] = state.get("context", {})
    replan_reason: str | None = state.get("replan_reason")
    replan_count: int = state.get("replan_count", 0)

    # On a replan, increment the counter before generating a new plan.
    if replan_reason is not None:
        replan_count += 1
        logger.info(
            "plan_and_run_node: replan attempt %d/%d — reason: %.120s",
            replan_count,
            _MAX_REPLANS,
            replan_reason,
        )
    else:
        logger.info("plan_and_run_node: generating initial plan")

    llm = ChatOpenAI(model="{{ planner_llm_model }}", temperature={{ planner_llm_temperature }})
    messages = _build_prompt(query, context, replan_reason)

    response: AIMessage = await llm.ainvoke(messages, config=config)
    raw = response.content if hasattr(response, "content") else str(response)

    try:
        plan = _parse_plan(raw)
    except ValueError as exc:
        logger.error("plan_and_run_node: failed to parse LLM plan — %s", exc)
        # Treat unparseable response as a malformed plan; let precheck/validator surface it.
        plan = []

    logger.info("plan_and_run_node: plan has %d steps", len(plan))

    return {
        "plan": plan,
        "replan_count": replan_count,
        "replan_reason": None,   # clear previous error
        "step_results": {},      # reset solver results for new plan
    }
