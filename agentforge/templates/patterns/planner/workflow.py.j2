from __future__ import annotations

from typing import Any

from langgraph.graph import StateGraph, END, START
from typing_extensions import TypedDict

from .nodes.plan_and_run_node import plan_and_run_node
from .nodes.solver_node import solver_node
{% if planner_precheck_enabled %}
from .nodes.plan_precheck_node import plan_precheck_node
{% endif %}
{% if planner_validator_enabled %}
from .nodes.validator_node import validator_node
{% endif %}
{% if planner_composer_enabled %}
from .nodes.composer_node import composer_node
{% endif %}
from observability.logging import get_logger

logger = get_logger(__name__)

# ── Scaffold-time constants ───────────────────────────────────────────────────
_MAX_REPLANS: int = {{ planner_max_replans }}


# ── State definition ──────────────────────────────────────────────────────────

class PlannerState(TypedDict, total=False):
    """Shared state type for the planner pattern graph.

    All fields are optional (``total=False``) so nodes only need to return
    the fields they mutate.
    """
    # ── Input ──────────────────────────────────────────────────────────────────
    query: str
    context: dict[str, Any]
    # Tool registry: dict[tool_name, callable] — injected by the entry point.
    tool_registry: dict[str, Any]

    # ── Plan ───────────────────────────────────────────────────────────────────
    plan: list[dict[str, Any]]

    # ── Precheck ───────────────────────────────────────────────────────────────
    precheck_ok: bool

    # ── Solver ─────────────────────────────────────────────────────────────────
    step_results: dict[str, Any]
    solver_error: str | None

    # ── Validator ──────────────────────────────────────────────────────────────
    validator_verdict: str   # "continue" | "replan" | "done"

    # ── Replan loop ────────────────────────────────────────────────────────────
    replan_count: int
    replan_reason: str | None   # human-readable failure message

    # ── Output ─────────────────────────────────────────────────────────────────
    output: Any


# ── Routing functions ─────────────────────────────────────────────────────────
{% if planner_precheck_enabled %}

def _route_precheck(state: PlannerState) -> str:
    """Route after precheck: proceed to solver or replan.

    Forces END when the replan ceiling is reached to prevent infinite loops.
    """
    replan_count = state.get("replan_count", 0)
    if state.get("precheck_ok", False):
        return "solver"
    if replan_count >= _MAX_REPLANS:
        logger.warning(
            "_route_precheck: precheck failed and replan_count=%d >= max_replans=%d — forcing END",
            replan_count,
            _MAX_REPLANS,
        )
        return END
    return "plan_and_run"
{% endif %}
{% if planner_validator_enabled %}

def _route_validator(state: PlannerState) -> str:
    """Route after validator: compose, replan, or end.

    Forces compose/end when the replan ceiling is reached.
    """
    replan_count = state.get("replan_count", 0)
    verdict = state.get("validator_verdict", "continue")

    if verdict == "replan" and replan_count < _MAX_REPLANS:
        return "plan_and_run"

    # "continue", "done", or ceiling exhausted → proceed to compose or END.
{% if planner_composer_enabled %}
    return "composer"
{% else %}
    return END
{% endif %}
{% endif %}


# ── Graph assembly ────────────────────────────────────────────────────────────

def _build_graph() -> StateGraph:
    """Build the planner workflow graph.

    Returns:
        An uncompiled LangGraph ``StateGraph`` wired according to the
        scaffold-time configuration flags.
    """
    graph = StateGraph(PlannerState)

    # ── Register nodes ────────────────────────────────────────────────────────
    graph.add_node("plan_and_run", plan_and_run_node)
{% if planner_precheck_enabled %}
    graph.add_node("precheck", plan_precheck_node)
{% endif %}
    graph.add_node("solver", solver_node)
{% if planner_validator_enabled %}
    graph.add_node("validator", validator_node)
{% endif %}
{% if planner_composer_enabled %}
    graph.add_node("composer", composer_node)
{% endif %}

    # ── Entry edge ───────────────────────────────────────────────────────────
    graph.add_edge(START, "plan_and_run")

{% if planner_precheck_enabled %}
    # plan → precheck
    graph.add_edge("plan_and_run", "precheck")

    # precheck → solver (ok) | plan_and_run (replan) | END (ceiling exhausted)
    graph.add_conditional_edges(
        "precheck",
        _route_precheck,
        {
            "solver": "solver",
            "plan_and_run": "plan_and_run",
            END: END,
        },
    )
{% else %}
    # plan → solver (precheck disabled)
    graph.add_edge("plan_and_run", "solver")
{% endif %}

{% if planner_validator_enabled %}
    # solver → validator
    graph.add_edge("solver", "validator")

    # validator → compose/END (ok) | plan_and_run (replan)
    graph.add_conditional_edges(
        "validator",
        _route_validator,
        {
{% if planner_composer_enabled %}
            "composer": "composer",
{% else %}
            END: END,
{% endif %}
            "plan_and_run": "plan_and_run",
        },
    )
{% else %}
{% if planner_composer_enabled %}
    # solver → composer (validator disabled)
    graph.add_edge("solver", "composer")
{% else %}
    # solver → END (validator + composer both disabled)
    graph.add_edge("solver", END)
{% endif %}
{% endif %}

{% if planner_composer_enabled %}
    # composer → END
    graph.add_edge("composer", END)
{% endif %}

    return graph


# ── Compile once at module load ───────────────────────────────────────────────
_COMPILED_GRAPH = _build_graph().compile()
logger.info("workflow (planner): graph compiled and cached at startup")


def get_workflow() -> StateGraph:
    """Return the module-level singleton compiled graph."""
    return _COMPILED_GRAPH
