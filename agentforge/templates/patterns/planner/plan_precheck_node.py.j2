"""
plan_precheck_node.py — Structural DAG validation node for the planner pattern.
Auto-generated by agentforge (pattern: planner).

This node is a THIN WRAPPER around the pure ``_precheck.check_plan`` helper.
No LLM call is made here. All validation logic lives in ``_precheck.py``
so it can be unit-tested independently.

On failure:
  - Sets ``state["replan_reason"]`` to the structured error string.
  - Routes the graph back to ``plan_and_run`` (replan edge).
  - Counts against ``max_replans`` ({{ planner_max_replans }}).

On success:
  - Routes the graph forward to ``solver`` (proceed edge).

Config values injected at scaffold time:
    max_replans = {{ planner_max_replans }}
"""
from __future__ import annotations

from typing import Any

from langchain_core.runnables import RunnableConfig

from ..planner._precheck import check_plan
from observability.logging import get_logger

logger = get_logger(__name__)

_MAX_REPLANS: int = {{ planner_max_replans }}


async def plan_precheck_node(
    state: dict[str, Any], config: RunnableConfig
) -> dict[str, Any]:
    """Validate the current plan without calling an LLM.

    Reads ``state["plan"]`` and runs all structural checks:
    - JSON schema shape (required fields and types).
    - Tool refs resolve against the project's declared tool registry.
    - Dep refs point to declared step ids; no cycles.
    - JSON Pointer ``${stepN/...}`` args reference declared deps.

    Args:
        state: Current graph state dict.
        config: LangGraph runnable config (not used; accepted for signature compat).

    Returns:
        Partial state update dict. ``precheck_ok`` signals the routing function.
        ``replan_reason`` is set only on failure.
    """
    plan = state.get("plan", [])
    replan_count = state.get("replan_count", 0)

    ok, errors = check_plan(plan)

    if ok:
        logger.info(
            "plan_precheck_node: plan with %d steps passed all checks", len(plan)
        )
        return {"precheck_ok": True, "replan_reason": None}

    reason = "Plan failed structural precheck:\n" + "\n".join(f"  - {e}" for e in errors)
    logger.warning(
        "plan_precheck_node: precheck FAILED (replan_count=%d/%d) — %s",
        replan_count,
        _MAX_REPLANS,
        errors,
    )
    return {"precheck_ok": False, "replan_reason": reason}
