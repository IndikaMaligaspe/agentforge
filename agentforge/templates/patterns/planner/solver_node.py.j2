"""
solver_node.py — Concurrent plan-step executor for the planner pattern.
Auto-generated by agentforge (pattern: planner).

SCAFFOLD RISK — IDEMPOTENCY:
    On a replan, steps that already ran successfully may be executed again.
    Make ``http`` and ``agent`` tools idempotent or pass idempotency keys in
    args to prevent duplicate side-effects.

SCAFFOLD RISK — STATE SIZE:
    ``step_results`` accumulates one entry per completed step. For plans with
    many steps or long result payloads, the state dict may grow large.
    Consider summarising results before passing them to ComposerNode and
    enabling a checkpointer with a TTL to prune stale state.

Config values injected at scaffold time:
    max_concurrency = {{ planner_max_concurrency }}
    max_replans     = {{ planner_max_replans }}
"""
from __future__ import annotations

import asyncio
import json
import re
from collections import defaultdict
from typing import Any, Callable

from langchain_core.runnables import RunnableConfig

from observability.logging import get_logger

logger = get_logger(__name__)

_MAX_CONCURRENCY: int = {{ planner_max_concurrency }}

# ── JSON-Pointer resolver ─────────────────────────────────────────────────────
_REF_PATTERN: re.Pattern[str] = re.compile(r"\$\{([^/}]+)/([^}]+)\}")


def _resolve_refs(value: Any, step_results: dict[str, Any]) -> Any:
    """Recursively resolve ``${stepN/field}`` JSON Pointer references.

    Args:
        value: The value (string, dict, list, or scalar) to scan for refs.
        step_results: Dict mapping step ids to their completed results.

    Returns:
        The value with all resolvable refs substituted.
    """
    if isinstance(value, str):
        def _sub(m: re.Match) -> str:
            step_id = m.group(1)
            pointer = m.group(2)
            result = step_results.get(step_id, {})
            # Walk the pointer path (slash-separated).
            for part in pointer.split("/"):
                if isinstance(result, dict):
                    result = result.get(part, "")
                else:
                    result = ""
                    break
            return json.dumps(result) if not isinstance(result, str) else result
        return _REF_PATTERN.sub(_sub, value)
    if isinstance(value, dict):
        return {k: _resolve_refs(v, step_results) for k, v in value.items()}
    if isinstance(value, list):
        return [_resolve_refs(item, step_results) for item in value]
    return value


# ── Topological level builder ─────────────────────────────────────────────────

def _build_levels(plan: list[dict[str, Any]]) -> list[list[dict[str, Any]]]:
    """Group plan steps into dependency levels suitable for concurrent execution.

    Steps with no deps form level 0. Steps whose deps are all in earlier levels
    form the next level.  Steps within a level may run concurrently up to
    ``_MAX_CONCURRENCY``.

    Args:
        plan: Validated plan step list.

    Returns:
        List of levels, each a list of step dicts.
    """
    step_map = {s["id"]: s for s in plan}
    level_of: dict[str, int] = {}

    def _level(step_id: str) -> int:
        if step_id in level_of:
            return level_of[step_id]
        step = step_map[step_id]
        deps = step.get("deps", [])
        lvl = (max(_level(d) for d in deps) + 1) if deps else 0
        level_of[step_id] = lvl
        return lvl

    for step in plan:
        _level(step["id"])

    by_level: dict[int, list[dict[str, Any]]] = defaultdict(list)
    for step in plan:
        by_level[_level(step["id"])].append(step)

    return [by_level[i] for i in sorted(by_level)]


# ── Step executor ─────────────────────────────────────────────────────────────

async def _execute_step(
    step: dict[str, Any],
    step_results: dict[str, Any],
    tool_registry: dict[str, Callable],
) -> tuple[str, Any]:
    """Execute a single plan step with resolved args.

    Args:
        step: The plan step dict (id, tool, args, deps).
        step_results: Results already collected from completed steps.
        tool_registry: Mapping of tool name → callable.

    Returns:
        Tuple of ``(step_id, result)``.
    """
    step_id: str = step["id"]
    tool_name: str = step["tool"]
    raw_args: dict[str, Any] = step.get("args", {})

    resolved_args = _resolve_refs(raw_args, step_results)
    logger.debug("solver: executing step '%s' tool='%s'", step_id, tool_name)

    tool_fn = tool_registry.get(tool_name)
    if tool_fn is None:
        raise RuntimeError(
            f"solver: tool '{tool_name}' not found in registry. "
            "Ensure all tools are registered before invoking the solver."
        )

    # Support both sync and async tool callables.
    if asyncio.iscoroutinefunction(tool_fn):
        result = await tool_fn(**resolved_args)
    else:
        result = await asyncio.to_thread(tool_fn, **resolved_args)

    logger.debug("solver: step '%s' completed — result type=%s", step_id, type(result).__name__)
    return step_id, result


# ── Main solver node ──────────────────────────────────────────────────────────

async def solver_node(
    state: dict[str, Any], config: RunnableConfig
) -> dict[str, Any]:
    """Execute plan steps concurrently, respecting dependency order.

    Groups steps into topological levels using ``_build_levels``. Within each
    level, up to ``{{ planner_max_concurrency }}`` steps run concurrently via
    ``asyncio.gather``.  Steps in later levels run only after all steps in
    earlier levels complete.

    The caller must attach the tool_registry via ``state["tool_registry"]``.
    This should be a ``dict[str, Callable]`` mapping tool name → tool function.

    Args:
        state: Current graph state dict. Must include ``plan`` and
               optionally ``tool_registry`` and ``step_results``.
        config: LangGraph runnable config (passed through).

    Returns:
        Partial state update dict with updated ``step_results`` and
        ``solver_error`` (None on success, error string on failure).
    """
    plan: list[dict[str, Any]] = state.get("plan", [])
    tool_registry: dict[str, Callable] = state.get("tool_registry", {})
    step_results: dict[str, Any] = dict(state.get("step_results", {}))

    if not plan:
        logger.warning("solver_node: received empty plan — nothing to execute")
        return {"step_results": step_results, "solver_error": "empty plan"}

    levels = _build_levels(plan)
    semaphore = asyncio.Semaphore(_MAX_CONCURRENCY)
    logger.info(
        "solver_node: executing plan (%d steps, %d levels, max_concurrency=%d)",
        len(plan),
        len(levels),
        _MAX_CONCURRENCY,
    )

    async def _bounded(step: dict[str, Any]) -> tuple[str, Any]:
        async with semaphore:
            return await _execute_step(step, step_results, tool_registry)

    for level_idx, level_steps in enumerate(levels):
        logger.debug("solver_node: running level %d (%d steps)", level_idx, len(level_steps))
        tasks = [_bounded(step) for step in level_steps]
        try:
            results = await asyncio.gather(*tasks)
        except Exception as exc:
            logger.error("solver_node: step execution failed — %s", exc)
            return {
                "step_results": step_results,
                "solver_error": f"Step execution failed: {exc}",
            }
        for step_id, result in results:
            step_results[step_id] = result

    logger.info("solver_node: all %d steps completed", len(plan))
    return {"step_results": step_results, "solver_error": None}
