"""
validator_node.py — LLM-based post-execution plan coverage check (planner pattern).
Auto-generated by agentforge (pattern: planner).

SCAFFOLD RISK — IDEMPOTENCY:
    A ``replan`` verdict causes the solver to re-execute potentially non-idempotent
    tools. Ensure ``http`` / ``agent`` tools are idempotent or carry idempotency
    keys. See plan_and_run_node.py for the replan counter guard.

Config values injected at scaffold time:
    max_replans = {{ planner_max_replans }}

Possible verdicts returned in ``state["validator_verdict"]``:
    ``"continue"`` — proceed directly to compose (coverage good, no replan).
    ``"replan"``   — plan coverage insufficient; trigger replan.
    ``"done"``     — same as continue (alias used when max_replans exhausted).
"""
from __future__ import annotations

import json
from typing import Any

from langchain_openai import ChatOpenAI
from langchain_core.messages import AIMessage, SystemMessage, HumanMessage
from langchain_core.runnables import RunnableConfig

from observability.logging import get_logger

logger = get_logger(__name__)

_MAX_REPLANS: int = {{ planner_max_replans }}

_VALIDATOR_SYSTEM_PROMPT = """You are a plan coverage validator. Given the original user \
request and the results from executing a plan, decide whether the plan fully addressed the \
request.

Return EXACTLY one of these three tokens on a line by itself — nothing else:
  continue  — plan results fully address the request
  replan    — the plan was insufficient; a new plan is required
  done      — execution is complete (use when no further steps are possible)

If you return ``replan``, append a second line explaining what is missing or wrong."""


async def validator_node(
    state: dict[str, Any], config: RunnableConfig
) -> dict[str, Any]:
    """Grade plan coverage and decide whether to replan or proceed.

    Reads ``state["query"]``, ``state["plan"]``, and ``state["step_results"]``.
    Returns ``state["validator_verdict"]`` (``"continue"`` | ``"replan"`` | ``"done"``)
    and updates ``state["replan_reason"]`` when verdict is ``"replan"``.

    When ``state["replan_count"] >= {{ planner_max_replans }}``, the verdict is
    forced to ``"done"`` regardless of LLM output to prevent infinite loops.

    Args:
        state: Current graph state dict.
        config: LangGraph runnable config (passed through to LLM).

    Returns:
        Partial state update dict.
    """
    query: str = state.get("query", "")
    plan: list[dict[str, Any]] = state.get("plan", [])
    step_results: dict[str, Any] = state.get("step_results", {})
    replan_count: int = state.get("replan_count", 0)

    # Guard: if we've already hit the replan ceiling, force completion.
    if replan_count >= _MAX_REPLANS:
        logger.warning(
            "validator_node: replan_count=%d reached max_replans=%d — forcing 'done'",
            replan_count,
            _MAX_REPLANS,
        )
        return {"validator_verdict": "done", "replan_reason": None}

    # Summarise plan results for the LLM.
    results_summary = json.dumps(step_results, indent=2, default=str)
    plan_summary = json.dumps(
        [{"id": s.get("id"), "tool": s.get("tool")} for s in plan],
        indent=2,
    )

    messages = [
        SystemMessage(content=_VALIDATOR_SYSTEM_PROMPT),
        SystemMessage(content=f"Plan steps executed:\n{plan_summary}"),
        SystemMessage(content=f"Step results:\n{results_summary}"),
        HumanMessage(content=f"Original request:\n{query}"),
    ]

    llm = ChatOpenAI(model="{{ planner_llm_model }}", temperature={{ planner_llm_temperature }})
    response: AIMessage = await llm.ainvoke(messages, config=config)
    raw: str = (response.content if hasattr(response, "content") else str(response)).strip()

    # Parse first token as verdict.
    first_line = raw.splitlines()[0].strip().lower() if raw else ""
    extra_lines = "\n".join(raw.splitlines()[1:]).strip() if "\n" in raw else ""

    if first_line in ("continue", "done"):
        verdict = first_line
        replan_reason = None
        logger.info("validator_node: verdict='%s'", verdict)
    elif first_line == "replan":
        verdict = "replan"
        replan_reason = extra_lines or "Validator indicated replan without explanation."
        logger.info(
            "validator_node: verdict='replan' replan_count=%d/%d — reason: %.120s",
            replan_count,
            _MAX_REPLANS,
            replan_reason,
        )
    else:
        # Unrecognised response — treat as done to avoid infinite loops.
        logger.warning(
            "validator_node: unrecognised verdict %r — defaulting to 'continue'", first_line
        )
        verdict = "continue"
        replan_reason = None

    return {"validator_verdict": verdict, "replan_reason": replan_reason}
