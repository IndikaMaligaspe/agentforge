"""
_precheck.py — Pure precheck helper for the planner pattern.
Auto-generated by agentforge (pattern: planner).

This module contains NO LLM calls and has NO side-effects. It is a pure
function library that validates a plan dict against the declared tool registry
and returns structured errors. The thin wrapper node (plan_precheck_node.py)
calls ``check_plan`` and routes the graph accordingly.

Keeping logic here enables isolated unit-testing without running the full graph.

Config values injected at scaffold time:
    tools declared = {{ planner_tool_names | join(", ") if planner_tool_names else "(none)" }}
"""
from __future__ import annotations

import re
from collections import defaultdict
from typing import Any

# ── Scaffold-time tool registry ───────────────────────────────────────────────
# Populated from project.yaml at scaffold time.  The precheck validates all
# plan step ``tool`` references against this set.

_REGISTERED_TOOLS: frozenset[str] = frozenset([
{% for tool_name in planner_tool_names %}
    "{{ tool_name }}",
{% endfor %}
])

{% raw %}
# ── JSON-Pointer reference pattern ────────────────────────────────────────────
# Matches ${stepN/...} placeholders in step args.
_REF_PATTERN: re.Pattern[str] = re.compile(r"\$\{([^/}]+)/[^}]*\}")

# ── Required step fields ──────────────────────────────────────────────────────
_REQUIRED_FIELDS: frozenset[str] = frozenset({"id", "tool", "args", "deps"})


def _check_shape(plan: list[dict[str, Any]]) -> list[str]:
    """Verify every step has the required fields and correct types.

    Args:
        plan: List of step dicts to validate.

    Returns:
        List of error messages; empty when shape is valid.
    """
    errors: list[str] = []
    if not isinstance(plan, list):
        return [f"plan must be a list, got {type(plan).__name__}"]
    for i, step in enumerate(plan):
        if not isinstance(step, dict):
            errors.append(f"step[{i}] must be a dict, got {type(step).__name__}")
            continue
        missing = _REQUIRED_FIELDS - step.keys()
        if missing:
            errors.append(f"step[{i}] missing required fields: {sorted(missing)}")
            continue
        if not isinstance(step["id"], str) or not step["id"]:
            errors.append(f"step[{i}].id must be a non-empty string")
        if not isinstance(step["tool"], str) or not step["tool"]:
            errors.append(f"step[{i}].tool must be a non-empty string")
        if not isinstance(step["args"], dict):
            errors.append(f"step[{i}].args must be a dict, got {type(step['args']).__name__}")
        if not isinstance(step["deps"], list):
            errors.append(f"step[{i}].deps must be a list, got {type(step['deps']).__name__}")
    return errors


def _check_tool_refs(plan: list[dict[str, Any]], tool_registry: frozenset[str]) -> list[str]:
    """Verify every step's tool field names a registered tool.

    Args:
        plan: Validated (shape-correct) list of step dicts.
        tool_registry: Set of known tool names.

    Returns:
        List of error messages; empty when all tool refs resolve.
    """
    errors: list[str] = []
    for step in plan:
        tool = step.get("tool", "")
        if tool and tool not in tool_registry:
            errors.append(
                "step '{}' references unknown tool '{}'. "
                "Registered tools: {}".format(
                    step.get("id", "?"),
                    tool,
                    sorted(tool_registry) if tool_registry else "(none)",
                )
            )
    return errors


def _check_dep_refs(plan: list[dict[str, Any]]) -> list[str]:
    """Verify every dep in every step refers to a declared step id.

    Args:
        plan: Validated (shape-correct) list of step dicts.

    Returns:
        List of error messages; empty when all dep refs are valid.
    """
    errors: list[str] = []
    declared = {step["id"] for step in plan if isinstance(step.get("id"), str)}
    for step in plan:
        step_id = step.get("id", "?")
        for dep in step.get("deps", []):
            if dep not in declared:
                errors.append(
                    "step '{}' depends on undeclared step id '{}'. "
                    "Declared ids: {}".format(step_id, dep, sorted(declared))
                )
    return errors


def _check_no_cycles(plan: list[dict[str, Any]]) -> list[str]:
    """Detect dependency cycles via Kahn's topological sort algorithm.

    Args:
        plan: Validated (shape-correct, dep-refs-valid) list of step dicts.

    Returns:
        List of error messages; empty when there are no cycles.
    """
    # Build adjacency and in-degree maps.
    in_degree: dict[str, int] = {step["id"]: 0 for step in plan}
    adjacency: dict[str, list[str]] = defaultdict(list)
    for step in plan:
        for dep in step.get("deps", []):
            if dep in in_degree:
                adjacency[dep].append(step["id"])
                in_degree[step["id"]] += 1

    queue = [sid for sid, deg in in_degree.items() if deg == 0]
    visited = 0
    while queue:
        node = queue.pop(0)
        visited += 1
        for neighbour in adjacency.get(node, []):
            in_degree[neighbour] -= 1
            if in_degree[neighbour] == 0:
                queue.append(neighbour)

    if visited != len(plan):
        cyclic = [sid for sid, deg in in_degree.items() if deg > 0]
        return ["dependency cycle detected involving step(s): {}".format(sorted(cyclic))]
    return []


def _check_pointer_refs(plan: list[dict[str, Any]]) -> list[str]:
    """Verify JSON Pointer ${stepN/...} args reference a declared dep.

    A pointer ``${stepN/field}`` in step S is valid only when ``stepN`` is
    listed in ``S.deps``. This prevents dangling references that would fail
    at solve time.

    Args:
        plan: Validated (shape-correct) list of step dicts.

    Returns:
        List of error messages; empty when all pointer refs are valid.
    """
    errors: list[str] = []

    def _scan_value(value: Any) -> list[str]:
        """Recursively scan a value for ${...} pointers."""
        found: list[str] = []
        if isinstance(value, str):
            found.extend(_REF_PATTERN.findall(value))
        elif isinstance(value, dict):
            for v in value.values():
                found.extend(_scan_value(v))
        elif isinstance(value, list):
            for item in value:
                found.extend(_scan_value(item))
        return found

    for step in plan:
        step_id = step.get("id", "?")
        deps = set(step.get("deps", []))
        args = step.get("args", {})
        refs = _scan_value(args)
        for ref_step in refs:
            if ref_step not in deps:
                errors.append(
                    "step '{}' args reference '${{{}/...}}' but "
                    "'{}' is not in step's deps {}. "
                    "Add it to deps or remove the reference.".format(
                        step_id, ref_step, ref_step, sorted(deps)
                    )
                )
    return errors


def check_plan(
    plan: list[dict[str, Any]],
    tool_registry: frozenset[str] | None = None,
) -> tuple[bool, list[str]]:
    """Validate a plan dict and return ``(ok, errors)``.

    Runs all five checks in order:
    1. JSON schema shape — required fields and types.
    2. Tool refs — all ``tool`` values name a registered tool.
    3. Dep refs — all ``deps`` entries name a declared step id.
    4. No cycles — topological sort detects circular dependencies.
    5. JSON Pointer refs — ``${stepN/...}`` args are in the step's deps.

    Short-circuits after the first check that finds errors, since later checks
    depend on the assumptions of earlier ones (e.g. cycle check assumes valid
    dep refs).

    Args:
        plan: The plan list (typically from ``state["plan"]``).
        tool_registry: Set of known tool names. Defaults to ``_REGISTERED_TOOLS``
                       (baked in at scaffold time from project.yaml).

    Returns:
        A 2-tuple ``(ok, errors)`` where ``ok`` is True when all checks pass
        and ``errors`` is a list of human-readable error strings (empty on success).
    """
    registry = tool_registry if tool_registry is not None else _REGISTERED_TOOLS

    shape_errors = _check_shape(plan)
    if shape_errors:
        return False, shape_errors

    tool_errors = _check_tool_refs(plan, registry)
    if tool_errors:
        return False, tool_errors

    dep_errors = _check_dep_refs(plan)
    if dep_errors:
        return False, dep_errors

    cycle_errors = _check_no_cycles(plan)
    if cycle_errors:
        return False, cycle_errors

    pointer_errors = _check_pointer_refs(plan)
    if pointer_errors:
        return False, pointer_errors

    return True, []
