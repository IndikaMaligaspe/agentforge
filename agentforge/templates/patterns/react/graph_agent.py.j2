"""
Compiled LangGraph app factory for the react execution pattern.
Auto-generated by agentforge (pattern: react).

BREAKING: Anyone who overrode the old single-invoke agent stub must switch
pattern back to 'orchestrator' to keep the pre-v2 behavior.

This module exposes ``build_graph`` which assembles a two-node ReAct
StateGraph (agent node <-> tool node) and returns the compiled runnable.
The graph cycles until the model emits a response without tool_calls or
the step counter reaches max_steps.

Config values injected at scaffold time:
    max_steps   = {{ react_max_steps }}
    tool_choice = {{ react_tool_choice }}
    temperature = {{ react_temperature }}
    provider    = {{ router_llm_provider }}
"""
from __future__ import annotations

from typing import Any, Annotated
import operator

from langchain_openai import ChatOpenAI
from langchain_core.messages import AIMessage, BaseMessage, SystemMessage
from langchain_core.runnables import Runnable
from langgraph.graph import StateGraph, END, START
from langgraph.prebuilt import ToolNode
from typing_extensions import TypedDict

from observability.logging import get_logger

logger = get_logger(__name__)

_MAX_STEPS: int = {{ react_max_steps }}
_TOOL_CHOICE: str = "{{ react_tool_choice }}"
_TEMPERATURE: float = {{ react_temperature }}


class ReactAgentState(TypedDict):
    """Shared state type for the react pattern graph."""
    messages: Annotated[list[BaseMessage], operator.add]
    step_count: int


def build_graph(
    tools: list[Any],
    system_prompt: str,
    model: str,
    *,
    max_steps: int = _MAX_STEPS,
    tool_choice: str = _TOOL_CHOICE,
    temperature: float = _TEMPERATURE,
) -> Runnable:
    """Assemble and compile a ReAct StateGraph.

    Args:
        tools: LangChain-compatible tool callables to bind to the LLM.
        system_prompt: System message prepended to every agent invocation.
        model: LLM model identifier (e.g. ``"gpt-4o-mini"``).
        max_steps: Maximum agent<->tool cycles before the loop is forced to END.
            Defaults to the scaffold-time value ({{ react_max_steps }}).
        tool_choice: LangChain ``tool_choice`` setting (``"auto"`` or ``"required"``).
            Defaults to the scaffold-time value (``"{{ react_tool_choice }}``").
        temperature: LLM sampling temperature. Defaults to the scaffold-time value
            ({{ react_temperature }}).

    Returns:
        A compiled LangGraph ``Runnable`` ready for ``.invoke`` / ``.astream``.
    """
    llm = ChatOpenAI(model=model, temperature=temperature)
    if tools:
        llm = llm.bind_tools(tools, tool_choice=tool_choice)

    _system = SystemMessage(content=system_prompt)

    def agent_node(state: ReactAgentState) -> dict[str, Any]:
        response: AIMessage = llm.invoke([_system] + state["messages"])
        return {
            "messages": [response],
            "step_count": state["step_count"] + 1,
        }

    def _should_continue(state: ReactAgentState) -> str:
        if state["step_count"] >= max_steps:
            logger.warning("React graph reached max_steps (%d); terminating loop.", max_steps)
            return END
        last: BaseMessage = state["messages"][-1]
        if isinstance(last, AIMessage) and last.tool_calls:
            return "tools"
        return END

    graph = StateGraph(ReactAgentState)
    graph.add_node("agent", agent_node)
    graph.add_node("tools", ToolNode(tools))
    graph.add_edge(START, "agent")
    graph.add_conditional_edges("agent", _should_continue, {"tools": "tools", END: END})
    graph.add_edge("tools", "agent")
    return graph.compile()
