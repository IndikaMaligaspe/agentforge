_TOOLS = [{% for t in agent.tools %}{{ t.name }}, {% endfor %}]

# ── ReAct state ─────────────────────────────────────────────────────

class _ReactState(TypedDict):
    messages: Annotated[list[BaseMessage], operator.add]
    step_count: int


# ── Graph builder ────────────────────────────────────────────────────

def _build_graph():
    """Build and compile the ReAct StateGraph.

    The graph alternates between the agent node (LLM reasoning) and the
    tools node (tool execution) until the LLM emits a response without
    tool_calls or the step counter reaches max_steps.

    Config values injected at scaffold time:
        max_steps   = {{ react_max_steps }}
        tool_choice = {{ react_tool_choice }}
        temperature = {{ react_temperature }}
    """
    _max_steps: int = {{ react_max_steps }}
    _tool_choice: str = "{{ react_tool_choice }}"
    _temperature: float = {{ react_temperature }}

    llm = ChatOpenAI(model="{{ agent.llm_model }}", temperature=_temperature)
    if _TOOLS:
        llm = llm.bind_tools(_TOOLS, tool_choice=_tool_choice)

    def agent_node(state: _ReactState) -> dict[str, Any]:
        """Call the LLM with the current message history."""
        response: AIMessage = llm.invoke(
            [SystemMessage(content="""{{ agent.system_prompt }}""")] + state["messages"]
        )
        return {
            "messages": [response],
            "step_count": state["step_count"] + 1,
        }

    def _should_continue(state: _ReactState) -> str:
        """Route to 'tools' when there are pending tool calls and max_steps not reached.

        Routes to END when:
        - The last message has no tool_calls (model finished reasoning), or
        - step_count has reached max_steps (safety cap).
        """
        if state["step_count"] >= _max_steps:
            logger.warning(
                "{{ agent.class_name }} reached max_steps (%d); terminating loop.",
                _max_steps,
            )
            return END
        last: BaseMessage = state["messages"][-1]
        if isinstance(last, AIMessage) and last.tool_calls:
            return "tools"
        return END

    graph = StateGraph(_ReactState)
    graph.add_node("agent", agent_node)
    graph.add_node("tools", ToolNode(_TOOLS))
    graph.add_edge(START, "agent")
    graph.add_conditional_edges("agent", _should_continue, {"tools": "tools", END: END})
    graph.add_edge("tools", "agent")
    return graph.compile()


_GRAPH = _build_graph()


@AgentRegistry.register("{{ agent.key }}")
class {{ agent.class_name }}(BaseAgent):

    @property
    def name(self) -> str:
        return "{{ agent.key }}"

    @property
    def needs_validation(self) -> bool:
        return {{ agent.needs_validation }}

    {% if enable_tracing %}
    @observe(name="{{ agent.key }}_agent_run")
    {% endif %}
    def run(self, query: str) -> dict[str, Any]:
        """
        Execute the ReAct tool loop for the given query.

        The loop cycles between the agent reasoning node and the tool
        execution node until the model emits a final answer (no tool_calls)
        or the max_steps cap is reached.
        """
        initial_state: _ReactState = {
            "messages": [HumanMessage(content=query)],
            "step_count": 0,
        }
        try:
            final_state = _GRAPH.invoke(initial_state)
            # Extract the last AI message content as the output.
            output = ""
            for msg in reversed(final_state["messages"]):
                if isinstance(msg, AIMessage):
                    output = getattr(msg, "content", str(msg))
                    break
            return {
                "success": True,
                "output": output,
                "error": None,
                {% for k in agent.extra_return_keys %}
                "{{ k }}": None,
                {% endfor %}
            }
        except Exception as exc:
            logger.exception("{{ agent.class_name }}.run failed")
            return {"success": False, "output": "", "error": str(exc)}
