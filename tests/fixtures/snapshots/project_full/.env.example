# API Keys
OPENAI_API_KEY=your-openai-api-key-here


JWT_ISSUER=https://example.com

JWT_AUDIENCE=full-stack-agent-api

# Database Connection
DATABASE_URL=postgresql://username:password@localhost:5432/full_stack_agent
# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json  # json or text

# Tracing (langfuse)
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_PROJECT=your-project-name

# MCP (Model Context Protocol) servers
# JSON object mapping server name -> connection config
# Example: {"my-server": {"url": "https://mcp.example.com", "timeout": 30}}
# MCP_SERVERS={}
# MCP_TIMEOUT=30

# Server Settings
PORT=8000
HOST=0.0.0.0
WORKERS=1
RELOAD=true  # Set to false in production