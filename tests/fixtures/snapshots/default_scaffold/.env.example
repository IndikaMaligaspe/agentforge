# === LLM / AI PROVIDER KEYS ===
# API credentials for the language model provider(s) used by this service.
OPENAI_API_KEY=your-openai-api-key-here

# === AUTHENTICATION ===
# Secrets and identifiers required to authenticate inbound requests.
API_SECRET_KEY=your-api-key-here




# === DATABASE ===
# Primary datastore connection string; dialect is determined by db_backend choice.
DATABASE_URL=postgresql://username:password@localhost:5432/full_featured_project
# === LOGGING ===
# Controls verbosity and output format of the application logger.
LOG_LEVEL=INFO
LOG_FORMAT=json  # json or text

# === OBSERVABILITY / TRACING ===
# Distributed tracing and evaluation platform credentials.
# Tracing (langfuse)
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_PROJECT=your-project-name

# === MCP SERVERS ===
# Model Context Protocol server registry; uncomment and populate to enable.
# MCP (Model Context Protocol) servers
# JSON object mapping server name -> connection config
# Example: {"my-server": {"url": "https://mcp.example.com", "timeout": 30}}
# MCP_SERVERS={}
# MCP_TIMEOUT=30

# === SERVER ===
# Runtime binding, concurrency, and hot-reload settings for the ASGI server.
PORT=8000
HOST=0.0.0.0
WORKERS=1
RELOAD=true  # Set to false in production